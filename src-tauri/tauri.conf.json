{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ButterUp",
  "version": "0.2.1",
  "identifier": "io.github.butterup",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ButterUp",
        "width": 900,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "category": "Utility",
    "shortDescription": "One friendly place to update everything on Ubuntu and Debian",
    "longDescription": "ButterUp shows pending apt, snap and flatpak updates in one window, installs them with progress, checks for the common broken states (interrupted dpkg, broken dependencies, full /boot) and offers one-click guided repairs and cleanup.",
    "linux": {
      "deb": {
        "section": "admin",
        "recommends": ["packagekit", "pkexec"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    }
  }
}
